# MySQL 8.0 (SQLAlchemy asyncmy URL)
# Replace the placeholders with the supplied connection configuration.
DATABASE_URL=mysql+asyncmy://USERNAME:PASSWORD@HOST:3306/agent_interview

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM Provider: "anthropic" | "deepseek" | "openai"
LLM_PROVIDER=deepseek

# Anthropic API (used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your-anthropic-key-here

# DeepSeek API (used when LLM_PROVIDER=deepseek)
DEEPSEEK_API_KEY=your-deepseek-key-here
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# LLM Common Settings
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7
LLM_REQUEST_TIMEOUT=60

# Interview Defaults
DEFAULT_TOTAL_QUESTIONS=5
DEFAULT_TIME_LIMIT_MINUTES=30
ANSWER_TIMEOUT_SECONDS=120
MAX_SKIP_COUNT=3
SLIDING_WINDOW_SIZE=10

# Scoring
SCORING_CONSECUTIVE_GOOD=2
SCORING_CONSECUTIVE_POOR=2
